{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "actor": {
      "type": "string"
    },
    "evidence": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "gate_id": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "GO",
        "NO_GO",
        "GO_WITH_ACCEPTED_RESIDUAL_RISKS",
        "SKIPPED"
      ]
    }
  },
  "required": [
    "gate_id",
    "verdict",
    "evidence",
    "notes",
    "actor"
  ],
  "type": "object"
}
